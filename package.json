{
  "name": "fulcrum-repo-insights",
  "version": "1.0.0",
  "description": "Azure DevOps Extension — Repository Insights Hub",
  "scripts": {
    "start": "webpack serve --mode development --env mock",
    "dev": "node scripts/dev-start.js",
    "build": "webpack --mode production",
    "build:dev": "webpack --mode development",
    "watch": "webpack --mode development --watch",
    "package": "npm run build && tfx extension create --manifest-globs vss-extension.json --output-path packages",
    "publish": "tfx extension publish --manifest-globs vss-extension.json"
  },
  "dependencies": {
    "azure-devops-extension-api": "^4.0.0",
    "azure-devops-extension-sdk": "^4.0.0",
    "azure-devops-ui": "^2.167.0",
    "react": "^16.14.0",
    "react-dom": "^16.14.0"
  },
  "devDependencies": {
    "@types/react": "^16.9.0",
    "@types/react-dom": "^16.9.0",
    "copy-webpack-plugin": "^11.0.0",
    "css-loader": "^6.10.0",
    "sass": "^1.77.0",
    "sass-loader": "^14.2.0",
    "style-loader": "^3.3.4",
    "tfx-cli": "^0.16.0",
    "ts-loader": "^9.5.1",
    "typescript": "^5.4.5",
    "webpack": "^5.91.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.2.4"
  }
}
