{
  "manifestVersion": 1,
  "id": "fulcrum-repo-insights",
  "publisher": "ScottRupke",
  "version": "1.0.0",
  "name": "Fulcrum Repository Insights",
  "description": "Repository overview with GitHub-style language breakdown, LOC metrics, and up to 10 configurable custom metadata columns.",
  "public": true,
  "categories": ["Azure Repos"],
  "targets": [
    {
      "id": "Microsoft.VisualStudio.Services"
    }
  ],
  "icons": {
    "default": "images/logo.png"
  },
  "contributions": [
    {
      "id": "hub",
      "type": "ms.vss-web.hub",
      "targets": ["ms.vss-code-web.code-hub-group"],
      "properties": {
        "name": "Repo Insights",
        "order": 98,
        "uri": "dist/hub/hub.html"
      }
    },
    {
      "id": "admin-hub",
      "type": "ms.vss-web.hub",
      "targets": ["ms.vss-admin-web.project-admin-hub-group"],
      "properties": {
        "name": "Repo Insights Admin",
        "order": 99,
        "uri": "dist/admin/admin.html"
      }
    }
  ],
  "files": [
    {
      "path": "dist",
      "addressable": true
    },
    {
      "path": "images",
      "addressable": true
    },
    {
      "path": "overview.md",
      "assetType": "Microsoft.VisualStudio.Services.Content.Details",
      "addressable": true
    },
    {
      "path": "LICENSE",
      "assetType": "Microsoft.VisualStudio.Services.Content.License",
      "addressable": true
    },
    {
      "path": "privacy.md",
      "assetType": "Microsoft.VisualStudio.Services.Content.Privacy",
      "addressable": true
    }
  ],
  "scopes": [
    "vso.code",
    "vso.project"
  ],
  "license": "LICENSE",
  "links": {
    "repository": {
      "uri": "https://github.com/srupke/Fulcrum.ADO.RepositoryInsights"
    },
    "issues": {
      "uri": "https://github.com/srupke/Fulcrum.ADO.RepositoryInsights/issues"
    },
    "support": {
      "uri": "https://github.com/srupke/Fulcrum.ADO.RepositoryInsights/issues"
    },
    "license": {
      "uri": "https://github.com/srupke/Fulcrum.ADO.RepositoryInsights/blob/main/LICENSE"
    },
    "privacypolicy": {
      "uri": "https://github.com/srupke/Fulcrum.ADO.RepositoryInsights/blob/main/privacy.md"
    }
  }
}
